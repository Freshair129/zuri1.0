# Facebook Messenger
FACEBOOK_VERIFY_TOKEN=
FB_ACCESS_TOKEN=
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=
FB_BUSINESS_ID=

# LINE OA
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Pusher (Realtime)
PUSHER_APP_ID=
PUSHER_APP_SECRET=
