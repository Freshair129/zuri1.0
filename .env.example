# ============================================
# Zuri Platform — Environment Variables
# Copy to .env.local — NEVER commit .env.local
# ============================================

# ── App ──────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ── Auth (NextAuth.js v4) ─────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-32-char-secret

# ── Database (Supabase PostgreSQL + Prisma) ───
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Cache (Upstash Redis) ─────────────────────
UPSTASH_REDIS_REST_URL=https://[REGION].upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Queue (Upstash QStash) ────────────────────
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# ── Realtime (Pusher Channels) ────────────────
PUSHER_APP_ID=your-app-id
PUSHER_APP_SECRET=your-app-secret
PUSHER_APP_CLUSTER=ap1
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key
NEXT_PUBLIC_PUSHER_CLUSTER=ap1

# ── AI (Google Gemini 2.0 Flash) ─────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Facebook Messenger ────────────────────────
# Webhook verify token — set in Meta Developer Portal
FACEBOOK_VERIFY_TOKEN=your-webhook-verify-token
# Page Access Token + Page ID — stored per-tenant in DB (not here)
# FB_PAGE_ACCESS_TOKEN and FB_PAGE_ID are tenant secrets → stored in tenant table

# ── LINE OA ───────────────────────────────────
# Channel Secret — used to verify X-Line-Signature HMAC
LINE_CHANNEL_SECRET=your-line-channel-secret
# Channel Access Token — stored per-tenant in DB (not here)

# ── Vercel ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
VERCEL_PROTECTION_BYPASS=

# ─────────────────────────────────────────────
# Per-tenant secrets (stored in DB, not .env):
#   tenant.fbPageToken       — FB Page Access Token
#   tenant.fbPageId          — FB Page ID
#   tenant.fbBusinessId      — Meta Business ID (for Ads sync)
#   tenant.lineChannelToken  — LINE Channel Access Token
#   tenant.geminiKey         — Gemini key override (AI add-on)
#   tenant.flowAccountToken  — FlowAccount API token (Accounting add-on)
# ─────────────────────────────────────────────
